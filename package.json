{
  "name": "wraeclast-field-notes",
  "version": "0.4.0",
  "description": "Local-first field research companion for gathering poe.how Codex strategy data.",
  "author": "C-Pettersson",
  "license": "MIT",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "assets:sync:cards": "node tools/sync-divination-card-art.mjs",
    "assets:sync:items": "node tools/sync-poe-item-data.mjs",
    "dev": "npm run build && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run typecheck && npm run clean && vite build && tsc -p tsconfig.node.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "pack": "npm run build && cross-env ELECTRON_BUILDER_CACHE=.cache/electron-builder electron-builder --dir",
    "dist": "npm run build && cross-env ELECTRON_BUILDER_CACHE=.cache/electron-builder electron-builder",
    "dist:publish": "npm run build && cross-env ELECTRON_BUILDER_CACHE=.cache/electron-builder electron-builder --publish always",
    "release": "release-it"
  },
  "dependencies": {
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@vitejs/plugin-react": "^4.4.1",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^24.10.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "release-it": "^20.2.1",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "how.poe.fieldnotes",
    "productName": "Wraeclast Field Notes",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/renderer/assets/wraeclast-field-notes.png",
        "to": "wraeclast-field-notes.png"
      }
    ],
    "win": {
      "icon": "src/renderer/assets/wraeclast-field-notes.png",
      "signExecutable": false,
      "target": [
        "portable",
        "zip"
      ]
    },
    "portable": {
      "artifactName": "Wraeclast-Field-Notes-${version}-portable.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "C-Pettersson",
        "repo": "wraeclast-field-notes",
        "releaseType": "release"
      }
    ]
  }
}
